generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  // Runtime: Supabase transaction pooler (:6543, pgbouncer) — safe for serverless.
  url       = env("DATABASE_URL")
  // Migrations / db push: session pooler (:5432) — pgbouncer can't run them.
  directUrl = env("DIRECT_URL")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ResourceType {
  LINK
  AI_CHAT
  PDF
  BOOK
}

enum Recurrence {
  DAILY
  WEEKLY
  MONTHLY
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String?  // hashed password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subjects  Subject[]
  tasks     Task[]
  resources Resource[]
}

model Subject {
  id          String   @id @default(uuid())
  title       String
  description String?
  color       String?  // optional accent color for the subject card
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  milestones  Milestone[]
  resources   Resource[]
  tasks       Task[]
}

model Milestone {
  id          String   @id @default(uuid())
  title       String
  notes       String   @default("") // markdown
  order       Int      @default(0)  // manual ordering within a subject
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId   String

  tasks       Task[]
}

model Task {
  id            String         @id @default(uuid())
  title         String
  description   String?        // markdown notes for the task
  isCompleted   Boolean        @default(false)
  completedAt   DateTime?
  dueDate       DateTime?
  priority      Priority       @default(MEDIUM)
  estimatedTime Int?           // estimate in minutes
  timeSpent     Int?           // total actual minutes (updated on timer stop)
  recurrence    Recurrence?    // null = one-off; otherwise spawns next instance on completion
  order         Int            @default(0) // manual ordering within its milestone / loose list
  createdAt     DateTime       @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String

  // A task always belongs to a subject; a milestone is optional.
  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId     String

  milestone     Milestone?     @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  milestoneId   String?

  subtasks      Subtask[]
  timerSessions TimerSession[]
}

// A lightweight checklist item under a Task. Scoped to a user through its task's
// subject (no userId of its own), mirroring how Milestone is scoped.
model Subtask {
  id          String    @id @default(uuid())
  title       String
  notes       String    @default("") // markdown
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)  // manual ordering within its sibling group (taskId + parentId)
  createdAt   DateTime  @default(now())

  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId      String

  // Self-nesting: a subtask may sit under another subtask of the same task.
  // The UI caps depth at one level (children can't have children).
  parent      Subtask?  @relation("SubtaskChildren", fields: [parentId], references: [id], onDelete: Cascade)
  parentId    String?
  children    Subtask[] @relation("SubtaskChildren")
}

model Resource {
  id        String       @id @default(uuid())
  type      ResourceType
  url       String
  title     String
  note      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  subject   Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId String
}

model TimerSession {
  id        String    @id @default(uuid())
  startedAt DateTime
  endedAt   DateTime?
  duration  Int?      // in minutes

  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
}
